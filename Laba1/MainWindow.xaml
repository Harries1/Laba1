<Window x:Class="HardwareMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hardware Monitor" Height="650" Width="1000">

    <DockPanel>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="10">
            <Button Content="Обновить" Click="Refresh_Click" Width="120" Margin="5"/>
            <Button Content="Экспорт TXT" Click="ExportTxt_Click" Width="120" Margin="5"/>
            <Button Content="Экспорт CSV" Click="ExportCsv_Click" Width="120" Margin="5"/>
            <Button Content="Экспорт JSON" Click="ExportJson_Click" Width="120" Margin="5"/>
        </StackPanel>

        <TabControl Margin="10">

            <TabItem Header="CPU">
                <TextBox x:Name="CpuBox" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
            </TabItem>

            <TabItem Header="RAM">
                <TextBox x:Name="RamBox" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
            </TabItem>

            <TabItem Header="Диски">
                <TextBox x:Name="DiskBox" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
            </TabItem>

            <TabItem Header="Видео">
                <TextBox x:Name="VideoBox" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
            </TabItem>

            <TabItem Header="Сеть">
                <TextBox x:Name="NetworkBox" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
            </TabItem>

            <TabItem Header="Система">
                <TextBox x:Name="SystemBox" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>